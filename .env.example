# OpenRouter API Configuration
# REQUIRED: Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Mem0 Memory Configuration
# REQUIRED: Get your API key from: https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=m0-your-mem0-key-here

# Model Configuration (Optional)
# Default model to use for the agent
# Models compatible with zero data retention: anthropic/claude-3.5-haiku, meta-llama/llama-3.1-8b-instruct:free
MODEL_NAME=anthropic/claude-3.5-haiku

# Alternative models you can use:
# MODEL_NAME=meta-llama/llama-3.1-8b-instruct:free
# MODEL_NAME=microsoft/wizardlm-2-8x22b
# MODEL_NAME=qwen/qwen-2.5-7b-instruct
