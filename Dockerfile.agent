# Dockerfile.agent
#
# Multi-stage build for a Bindu agent (airbnb-travel-agent example).
# Builder: python:3.12-bookworm + uv
# Runtime: bindu-runtime-base

# ---------- Builder stage ----------
FROM python:3.12-bookworm AS builder

# Install uv once in builder (no need in runtime)
RUN pip install --no-cache-dir uv

ENV UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy
WORKDIR /app

# 1) Install dependencies into .venv (lockfile + pyproject)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project --no-dev

# 2) Copy agent code
COPY news_agent/ /app/news_agent/
COPY *.py /app/
COPY README.md /app/

# 3) Install project itself into the same venv
RUN uv sync --frozen --no-dev

# ---------- Runtime stage ----------
FROM raahulrahl/bindu-runtime-base:latest

# OCI labels
LABEL org.opencontainers.image.title="news-agent"
LABEL org.opencontainers.image.description="The news-agents project represents a sophisticated implementation of terminal-based multi-agent coordination for news aggregation. Its architecture demonstrates innovative use of tmux for visual agent management, MCP for tool integration, and template-driven content generation. The codebase is well-structured, comprehensively documented, and serves as an excellent reference for building distributed agent systems using modern AI tools and terminal technologies."
LABEL org.opencontainers.image.authors="Paras Chamoli <paras@getbindu.com>"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.source="https://github.com/Paraschamoli/news-agent"
LABEL org.opencontainers.image.licenses="MIT"

# Copy app + venv from builder
COPY --from=builder /app /app

# Use the agent venv Python by default
ENV PATH="/app/.venv/bin:$PATH"

WORKDIR /app
EXPOSE 3773

CMD ["python", "-m", "news_agent"]
